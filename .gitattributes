# Auto-detect text files and normalize to LF in the repo,
# checked out with the platform's native line ending unless overridden below.
* text=auto eol=lf

# ---------------------------------------------------------------------------
# Text files — force LF
# ---------------------------------------------------------------------------
*.kt        text eol=lf
*.kts       text eol=lf
*.java      text eol=lf
*.xml       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.properties text eol=lf
*.toml      text eol=lf
*.pro       text eol=lf
*.cfg       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
gradlew     text eol=lf

# ---------------------------------------------------------------------------
# Windows-only scripts — force CRLF
# ---------------------------------------------------------------------------
*.bat       text eol=crlf
*.cmd       text eol=crlf
gradlew.bat text eol=crlf

# ---------------------------------------------------------------------------
# Binary — never convert
# ---------------------------------------------------------------------------
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.jar       binary
*.aar       binary
*.apk       binary
*.aab       binary
*.keystore  binary
*.jks       binary
*.so        binary
*.dex       binary
*.class     binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.zip       binary
*.gz        binary
*.pdf       binary
